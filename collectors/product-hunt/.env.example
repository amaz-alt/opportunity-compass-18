# --- Required: Database / API ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Required: Product Hunt API v2 (GraphQL) ---
# Create a developer token at https://api.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=your-product-hunt-developer-token

# --- Collector identity ---
# Either supply COLLECTOR_ID (uuid of an existing row in `collectors`)
# or COLLECTOR_NAME + COLLECTOR_PLATFORM to auto-provision/lookup.
COLLECTOR_ID=
COLLECTOR_NAME=Product Hunt
COLLECTOR_PLATFORM=producthunt

# --- Runtime ---
PORT=8080
LOG_LEVEL=info

# Polling interval in seconds (default 15 min). Also read from collectors.config.poll_interval_seconds if present.
POLL_INTERVAL_SECONDS=900

# Max posts to fetch per run
POSTS_PER_RUN=40

# Max comments to fetch per post
COMMENTS_PER_POST=50

# Start collector loop automatically at boot
AUTOSTART=true

# Retry / backoff
MAX_RETRIES=5
RETRY_BASE_MS=1000
